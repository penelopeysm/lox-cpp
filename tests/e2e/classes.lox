class Dog {
    speak() {
        print "Woof!";
    }

    // Some dogs know their own name.
    speak_clever() {
        print "Hi! My name is " + this.name + ". Woof!";
    }
}
print Dog;         // <class Dog>

var d = Dog();
print d;           // <instance of <class Dog>>
d.speak();         // "Woof!"

var woof = d.speak;
woof();            // "Woof!"

var cleverd = Dog();
cleverd.name = "Heidi";
cleverd.speak_clever();  // "Hi! My name is Heidi. Woof!"
